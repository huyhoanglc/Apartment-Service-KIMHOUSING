PORT=5000
DATABASE_URL="postgresql://user:password@localhost:5432/apartments"
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

EMAIL_USER=
EMAIL_APP_PASSWORD=

# Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client ID (Web application)
GOOGLE_CLIENT_ID=

# Google Sheets sync (Employee data source, service account, read-only)
# GOOGLE_SHEET_ID la ID trong URL cua Sheet: https://docs.google.com/spreadsheets/d/<ID>/edit
GOOGLE_SHEET_ID=
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
# Tuy chon: override lich cron (cu phap node-cron) va timezone cua job dong bo Employee
EMPLOYEE_SYNC_CRON=
EMPLOYEE_SYNC_TIMEZONE=
