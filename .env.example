# Dùng cho docker-compose.yml ở root - copy thành .env rồi điền giá trị thật
# (KHÔNG commit file .env thật lên git)

# --- Postgres ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=apartments

# --- Backend ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

EMAIL_USER=
EMAIL_APP_PASSWORD=

# Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client ID (Web application)
# Dùng chung 1 giá trị cho cả backend (verify) và admin-dashboard (nút đăng nhập)
GOOGLE_CLIENT_ID=
